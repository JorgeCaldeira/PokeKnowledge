    <!-- https://pokemonkg.org/ontology#PokéType_Fire -->

    <owl:NamedIndividual rdf:about="https://pokemonkg.org/ontology#PokéType_Fire">
        <rdf:type rdf:resource="https://pokemonkg.org/ontology#Type"/>
        <isResistantTo rdf:resource="https://pokemonkg.org/ontology#PokéType_Bug"/>
        <isResistantTo rdf:resource="https://pokemonkg.org/ontology#PokéType_Fairy"/>
