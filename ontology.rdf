        <rdf:type rdf:resource="https://pokemonkg.org/ontology#Habitat"/>
        <rdfs:label xml:lang="en">Cave</rdfs:label>
        <rdfs:label xml:lang="de">Höhle</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://pokemonkg.org/ontology#Habitat_Forest -->

    <owl:NamedIndividual rdf:about="https://pokemonkg.org/ontology#Habitat_Forest">
        <rdf:type rdf:resource="https://pokemonkg.org/ontology#Habitat"/>
        <rdfs:label xml:lang="en">Forest</rdfs:label>
        <rdfs:label xml:lang="de">Wald</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://pokemonkg.org/ontology#Habitat_Grassland -->

    <owl:NamedIndividual rdf:about="https://pokemonkg.org/ontology#Habitat_Grassland">
        <rdf:type rdf:resource="https://pokemonkg.org/ontology#Habitat"/>
        <rdfs:label xml:lang="de">Gras</rdfs:label>
        <rdfs:label xml:lang="en">Grassland</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://pokemonkg.org/ontology#Habitat_Mountain -->

    <owl:NamedIndividual rdf:about="https://pokemonkg.org/ontology#Habitat_Mountain">
        <rdf:type rdf:resource="https://pokemonkg.org/ontology#Habitat"/>
        <rdfs:label xml:lang="de">Berg</rdfs:label>
        <rdfs:label xml:lang="en">Mountain</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://pokemonkg.org/ontology#Habitat_Rare -->

    <owl:NamedIndividual rdf:about="https://pokemonkg.org/ontology#Habitat_Rare">
        <rdf:type rdf:resource="https://pokemonkg.org/ontology#Habitat"/>
        <rdfs:label xml:lang="en">Rare</rdfs:label>
        <rdfs:label xml:lang="de">Selten</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://pokemonkg.org/ontology#Habitat_RoughTerrain -->

    <owl:NamedIndividual rdf:about="https://pokemonkg.org/ontology#Habitat_RoughTerrain">
        <rdf:type rdf:resource="https://pokemonkg.org/ontology#Habitat"/>
        <rdfs:label xml:lang="en">Rough terrain</rdfs:label>
        <rdfs:label xml:lang="de">Wildnis</rdfs:label>
    </owl:NamedIndividual>
    


    <!-- https://pokemonkg.org/ontology#Habitat_Sea -->

