<?xml version="1.0"?>
<rdf:RDF xmlns="https://pokeknowledge.org/ontology#"
     xml:base="https://pokeknowledge.org/ontology"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:foaf="http://xmlns.com/foaf/0.1/"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">
    <owl:Ontology rdf:about="https://pokeknowledge.org/ontology">
        <owl:versionIRI rdf:resource="https://pokeknowledge.org/ontology/version/1.0.0"/>
        <rdfs:comment xml:lang="en">A Knowledge Graph for Pokémon and their types from the Pokémon Sword &amp; Shield Games.</rdfs:comment>
        <rdfs:label xml:lang="en">PokéKnowledge</rdfs:label>
    </owl:Ontology>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Datatypes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.w3.org/2001/XMLSchema#date -->

    <rdfs:Datatype rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://pokeknowledge.org/ontology#containsPlace -->

    <owl:ObjectProperty rdf:about="https://pokeknowledge.org/ontology#containsPlace">
        <owl:inverseOf rdf:resource="https://pokeknowledge.org/ontology#locatedIn"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="https://pokeknowledge.org/ontology#Place"/>
        <rdfs:range rdf:resource="https://pokeknowledge.org/ontology#Place"/>
        <rdfs:label xml:lang="en">contains place</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://pokeknowledge.org/ontology#describedInPokédex -->

    <owl:ObjectProperty rdf:about="https://pokeknowledge.org/ontology#describedInPokédex">
        <owl:inverseOf rdf:resource="https://pokeknowledge.org/ontology#describesPokémon"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
        <rdfs:domain rdf:resource="https://pokeknowledge.org/ontology#Pokémon"/>
        <rdfs:range rdf:resource="https://pokeknowledge.org/ontology#PokédexEntry"/>
        <rdfs:label xml:lang="en">described in Pokédex entry</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://pokeknowledge.org/ontology#describesPokémon -->

    <owl:ObjectProperty rdf:about="https://pokeknowledge.org/ontology#describesPokémon">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="https://pokeknowledge.org/ontology#PokédexEntry"/>
        <rdfs:range rdf:resource="https://pokeknowledge.org/ontology#Pokémon"/>
        <rdfs:label xml:lang="en">describes Pokémon</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://pokeknowledge.org/ontology#evolvesFrom -->

    <owl:ObjectProperty rdf:about="https://pokeknowledge.org/ontology#evolvesFrom">
        <owl:inverseOf rdf:resource="https://pokeknowledge.org/ontology#evolvesTo"/>
        <rdfs:domain rdf:resource="https://pokeknowledge.org/ontology#Pokémon"/>
        <rdfs:range rdf:resource="https://pokeknowledge.org/ontology#Pokémon"/>
        <rdfs:range>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://pokeknowledge.org/ontology#maxNumberOfPokémon"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
            </owl:Restriction>
        </rdfs:range>
        <rdfs:label xml:lang="en">evolves from</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://pokeknowledge.org/ontology#evolvesTo -->

    <owl:ObjectProperty rdf:about="https://pokeknowledge.org/ontology#evolvesTo">
        <rdfs:domain rdf:resource="https://pokeknowledge.org/ontology#Pokémon"/>
        <rdfs:domain>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://pokeknowledge.org/ontology#maxNumberOfPokémon"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
            </owl:Restriction>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://pokeknowledge.org/ontology#Pokémon"/>
        <rdfs:label xml:lang="en">evolves to</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://pokeknowledge.org/ontology#exclusiveToGame -->

    <owl:ObjectProperty rdf:about="https://pokeknowledge.org/ontology#exclusiveToGame">
        <rdfs:domain rdf:resource="https://pokeknowledge.org/ontology#Pokémon"/>
        <rdfs:range rdf:resource="https://pokeknowledge.org/ontology#Game"/>
        <rdfs:range>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://pokeknowledge.org/ontology#maxNumberOfPokémon"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
            </owl:Restriction>
        </rdfs:range>
        <rdfs:label xml:lang="en">exclusive to Game</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://pokeknowledge.org/ontology#featuresSpecies -->

    <owl:ObjectProperty rdf:about="https://pokeknowledge.org/ontology#featuresSpecies">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdfs:range rdf:resource="https://pokeknowledge.org/ontology#Pokémon"/>
        <owl:propertyChainAxiom rdf:parseType="Collection">
            <rdf:Description rdf:about="https://pokeknowledge.org/ontology#hasPokédexEntry"/>
            <rdf:Description rdf:about="https://pokeknowledge.org/ontology#describesPokémon"/>
        </owl:propertyChainAxiom>
        <rdfs:label xml:lang="en">features Species</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://pokeknowledge.org/ontology#foundIn -->

    <owl:ObjectProperty rdf:about="https://pokeknowledge.org/ontology#foundIn">
        <rdfs:domain rdf:resource="https://pokeknowledge.org/ontology#Pokémon"/>
        <rdfs:range rdf:resource="https://pokeknowledge.org/ontology#Habitat"/>
        <rdfs:label xml:lang="en">found in</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://pokeknowledge.org/ontology#hasGame -->

    <owl:ObjectProperty rdf:about="https://pokeknowledge.org/ontology#hasGame">
        <owl:inverseOf rdf:resource="https://pokeknowledge.org/ontology#hasRegion"/>
        <rdfs:domain rdf:resource="https://pokeknowledge.org/ontology#Generation"/>
        <rdfs:domain rdf:resource="https://pokeknowledge.org/ontology#Region"/>
        <rdfs:range rdf:resource="https://pokeknowledge.org/ontology#Game"/>
        <owl:propertyDisjointWith rdf:resource="https://pokeknowledge.org/ontology#hasRegion"/>
        <rdfs:label xml:lang="en">has Game</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://pokeknowledge.org/ontology#hasLeader -->

    <owl:ObjectProperty rdf:about="https://pokeknowledge.org/ontology#hasLeader">
        <owl:inverseOf rdf:resource="https://pokeknowledge.org/ontology#isLeaderOfGym"/>
        <rdfs:domain rdf:resource="https://pokeknowledge.org/ontology#Gym"/>
        <rdfs:range rdf:resource="https://pokeknowledge.org/ontology#GymLeader"/>
        <rdfs:label xml:lang="en">has Leader</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://pokeknowledge.org/ontology#hasMove -->

    <owl:ObjectProperty rdf:about="https://pokeknowledge.org/ontology#hasMove">
        <rdfs:domain rdf:resource="https://pokeknowledge.org/ontology#Pokémon"/>
        <rdfs:domain>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://pokeknowledge.org/ontology#minMovesInActiveMoveset"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
            </owl:Restriction>
        </rdfs:domain>
        <rdfs:domain>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://pokeknowledge.org/ontology#maxMovesInActiveMoveset"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">4</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
            </owl:Restriction>
        </rdfs:domain>
        <rdfs:range rdf:resource="https://pokeknowledge.org/ontology#Move"/>
        <rdfs:range>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://pokeknowledge.org/ontology#minMovesInActiveMoveset"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
            </owl:Restriction>
        </rdfs:range>
        <rdfs:range>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://pokeknowledge.org/ontology#maxMovesInActiveMoveset"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">4</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
            </owl:Restriction>
        </rdfs:range>
        <rdfs:label xml:lang="en">has Move</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://pokeknowledge.org/ontology#hasPokédexEntry -->

    <owl:ObjectProperty rdf:about="https://pokeknowledge.org/ontology#hasPokédexEntry">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
        <rdfs:domain rdf:resource="https://pokeknowledge.org/ontology#Pokédex"/>
        <rdfs:range rdf:resource="https://pokeknowledge.org/ontology#PokédexEntry"/>
        <rdfs:label xml:lang="en">has Pokédex entry</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://pokeknowledge.org/ontology#hasPokémonInTeam -->

    <owl:ObjectProperty rdf:about="https://pokeknowledge.org/ontology#hasPokémonInTeam">
        <rdfs:domain rdf:resource="https://pokeknowledge.org/ontology#Trainer"/>
        <rdfs:range rdf:resource="https://pokeknowledge.org/ontology#Pokémon"/>
        <rdfs:label xml:lang="en">has Pokémon in Team</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://pokeknowledge.org/ontology#hasRegion -->

    <owl:ObjectProperty rdf:about="https://pokeknowledge.org/ontology#hasRegion">
        <rdfs:domain rdf:resource="https://pokeknowledge.org/ontology#Game"/>
        <rdfs:range rdf:resource="https://pokeknowledge.org/ontology#Region"/>
        <rdfs:label xml:lang="en">has Region</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://pokeknowledge.org/ontology#hasSize -->

    <owl:ObjectProperty rdf:about="https://pokeknowledge.org/ontology#hasSize">
        <rdfs:label xml:lang="en">has size</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://pokeknowledge.org/ontology#hasTeam -->

    <owl:ObjectProperty rdf:about="https://pokeknowledge.org/ontology#hasTeam">
        <rdfs:domain rdf:resource="https://pokeknowledge.org/ontology#Trainer"/>
        <rdfs:range rdf:resource="https://pokeknowledge.org/ontology#Pokémon"/>
        <rdfs:range rdf:resource="https://pokeknowledge.org/ontology#Team"/>
        <rdfs:range>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://pokeknowledge.org/ontology#minNumberOfPokémon"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
            </owl:Restriction>
        </rdfs:range>
        <rdfs:range>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://pokeknowledge.org/ontology#maxNumberOfPokémon"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">6</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
            </owl:Restriction>
        </rdfs:range>
        <rdfs:label xml:lang="en">has Team</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://pokeknowledge.org/ontology#hasType -->

    <owl:ObjectProperty rdf:about="https://pokeknowledge.org/ontology#hasType">
        <rdfs:domain rdf:resource="https://pokeknowledge.org/ontology#Move"/>
        <rdfs:domain rdf:resource="https://pokeknowledge.org/ontology#Pokémon"/>
        <rdfs:range rdf:resource="https://pokeknowledge.org/ontology#Type"/>
        <rdfs:range>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://pokeknowledge.org/ontology#minNumPokémonTypes"/>
                <owl:minQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:minQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
            </owl:Restriction>
        </rdfs:range>
        <rdfs:range>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://pokeknowledge.org/ontology#moveType"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#int"/>
            </owl:Restriction>
        </rdfs:range>
        <rdfs:range>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://pokeknowledge.org/ontology#maxNumPokémonTypes"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">2</owl:maxQualifiedCardinality>
                <owl:onDataRange rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
            </owl:Restriction>
        </rdfs:range>
        <rdfs:label xml:lang="en">has Type</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://pokeknowledge.org/ontology#has_Gym -->

    <owl:ObjectProperty rdf:about="https://pokeknowledge.org/ontology#has_Gym">
        <owl:inverseOf rdf:resource="https://pokeknowledge.org/ontology#is_located_in_Town"/>
        <rdfs:domain rdf:resource="https://pokeknowledge.org/ontology#Gym"/>
        <rdfs:range rdf:resource="https://pokeknowledge.org/ontology#Town"/>
        <rdfs:label xml:lang="en">has Gym</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://pokeknowledge.org/ontology#isHarmlessAgainst -->

    <owl:ObjectProperty rdf:about="https://pokeknowledge.org/ontology#isHarmlessAgainst">
        <owl:inverseOf rdf:resource="https://pokeknowledge.org/ontology#isImmuneTo"/>
        <rdfs:domain rdf:resource="https://pokeknowledge.org/ontology#Type"/>
        <rdfs:range rdf:resource="https://pokeknowledge.org/ontology#Type"/>
        <owl:propertyDisjointWith rdf:resource="https://pokeknowledge.org/ontology#isSuperEffectiveAgainst"/>
        <owl:propertyDisjointWith rdf:resource="https://pokeknowledge.org/ontology#isWeakAgainst"/>
        <rdfs:label xml:lang="en">is Harmless against</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://pokeknowledge.org/ontology#isImmuneTo -->

    <owl:ObjectProperty rdf:about="https://pokeknowledge.org/ontology#isImmuneTo">
        <rdfs:domain rdf:resource="https://pokeknowledge.org/ontology#Type"/>
        <rdfs:range rdf:resource="https://pokeknowledge.org/ontology#Type"/>
        <owl:propertyDisjointWith rdf:resource="https://pokeknowledge.org/ontology#isResistantTo"/>
        <owl:propertyDisjointWith rdf:resource="https://pokeknowledge.org/ontology#isVulnerableTo"/>
        <rdfs:label xml:lang="en">is Immune to</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://pokeknowledge.org/ontology#isInTeam -->

    <owl:ObjectProperty rdf:about="https://pokeknowledge.org/ontology#isInTeam">
        <rdfs:domain rdf:resource="https://pokeknowledge.org/ontology#Pokémon"/>
        <rdfs:range rdf:resource="https://pokeknowledge.org/ontology#Team"/>
        <rdfs:label xml:lang="en">is In Team</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://pokeknowledge.org/ontology#isLeaderOfGym -->

    <owl:ObjectProperty rdf:about="https://pokeknowledge.org/ontology#isLeaderOfGym">
        <rdfs:domain rdf:resource="https://pokeknowledge.org/ontology#GymLeader"/>
        <rdfs:range rdf:resource="https://pokeknowledge.org/ontology#Gym"/>
        <rdfs:label xml:lang="en">is leader of gym</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://pokeknowledge.org/ontology#isResistantTo -->

    <owl:ObjectProperty rdf:about="https://pokeknowledge.org/ontology#isResistantTo">
        <owl:inverseOf rdf:resource="https://pokeknowledge.org/ontology#isWeakAgainst"/>
        <rdfs:domain rdf:resource="https://pokeknowledge.org/ontology#Type"/>
        <rdfs:range rdf:resource="https://pokeknowledge.org/ontology#Type"/>
        <owl:propertyDisjointWith rdf:resource="https://pokeknowledge.org/ontology#isVulnerableTo"/>
        <rdfs:label xml:lang="en">is Resistant to</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://pokeknowledge.org/ontology#isSuperEffectiveAgainst -->

    <owl:ObjectProperty rdf:about="https://pokeknowledge.org/ontology#isSuperEffectiveAgainst">
        <owl:inverseOf rdf:resource="https://pokeknowledge.org/ontology#isVulnerableTo"/>
        <rdfs:domain rdf:resource="https://pokeknowledge.org/ontology#Type"/>
        <rdfs:range rdf:resource="https://pokeknowledge.org/ontology#Type"/>
        <owl:propertyDisjointWith rdf:resource="https://pokeknowledge.org/ontology#isWeakAgainst"/>
        <rdfs:label xml:lang="en">is Super Effective against</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://pokeknowledge.org/ontology#isVulnerableTo -->

    <owl:ObjectProperty rdf:about="https://pokeknowledge.org/ontology#isVulnerableTo">
        <rdfs:domain rdf:resource="https://pokeknowledge.org/ontology#Type"/>
        <rdfs:range rdf:resource="https://pokeknowledge.org/ontology#Type"/>
        <rdfs:label xml:lang="en">is Vulnerable to</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://pokeknowledge.org/ontology#isWeakAgainst -->

    <owl:ObjectProperty rdf:about="https://pokeknowledge.org/ontology#isWeakAgainst">
        <rdfs:domain rdf:resource="https://pokeknowledge.org/ontology#Type"/>
        <rdfs:range rdf:resource="https://pokeknowledge.org/ontology#Type"/>
        <rdfs:label xml:lang="en">is Weak against</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://pokeknowledge.org/ontology#is_located_in_Town -->

    <owl:ObjectProperty rdf:about="https://pokeknowledge.org/ontology#is_located_in_Town">
        <rdfs:domain rdf:resource="https://pokeknowledge.org/ontology#Town"/>
        <rdfs:range rdf:resource="https://pokeknowledge.org/ontology#Gym"/>
        <rdfs:label xml:lang="en">is located in Town</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://pokeknowledge.org/ontology#learnsMove -->

    <owl:ObjectProperty rdf:about="https://pokeknowledge.org/ontology#learnsMove">
        <rdfs:domain rdf:resource="https://pokeknowledge.org/ontology#MoveLearning"/>
        <rdfs:range rdf:resource="https://pokeknowledge.org/ontology#Move"/>
        <rdfs:label xml:lang="en">learns Move</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://pokeknowledge.org/ontology#locatedIn -->

    <owl:ObjectProperty rdf:about="https://pokeknowledge.org/ontology#locatedIn">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#AsymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdfs:domain rdf:resource="https://pokeknowledge.org/ontology#Place"/>
        <rdfs:range rdf:resource="https://pokeknowledge.org/ontology#Place"/>
        <rdfs:label xml:lang="en">located in</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://pokeknowledge.org/ontology#mayHaveAbility -->

    <owl:ObjectProperty rdf:about="https://pokeknowledge.org/ontology#mayHaveAbility">
        <rdfs:domain rdf:resource="https://pokeknowledge.org/ontology#Pokémon"/>
        <rdfs:range rdf:resource="https://pokeknowledge.org/ontology#Ability"/>
        <rdfs:label xml:lang="en">may have Ability</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- https://pokeknowledge.org/ontology#mayHaveHiddenAbility -->

    <owl:ObjectProperty rdf:about="https://pokeknowledge.org/ontology#mayHaveHiddenAbility">
        <rdfs:subPropertyOf rdf:resource="https://pokeknowledge.org/ontology#mayHaveAbility"/>
        <rdfs:domain rdf:resource="https://pokeknowledge.org/ontology#Pokémon"/>
        <rdfs:range rdf:resource="https://pokeknowledge.org/ontology#Ability"/>
        <rdfs:label xml:lang="en">may have hidden ability</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- https://pokeknowledge.org/ontology#accuracy -->

    <owl:DatatypeProperty rdf:about="https://pokeknowledge.org/ontology#accuracy">
        <rdfs:domain rdf:resource="https://pokeknowledge.org/ontology#Move"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label xml:lang="en">has accuracy</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://pokeknowledge.org/ontology#attack -->

    <owl:DatatypeProperty rdf:about="https://pokeknowledge.org/ontology#attack">
        <rdfs:domain rdf:resource="https://pokeknowledge.org/ontology#Pokémon"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label xml:lang="en">has Attack</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://pokeknowledge.org/ontology#basePower -->

    <owl:DatatypeProperty rdf:about="https://pokeknowledge.org/ontology#basePower">
        <rdfs:domain rdf:resource="https://pokeknowledge.org/ontology#Move"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label xml:lang="en">has base power</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://pokeknowledge.org/ontology#basePowerPoints -->

    <owl:DatatypeProperty rdf:about="https://pokeknowledge.org/ontology#basePowerPoints">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="https://pokeknowledge.org/ontology#Move"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label xml:lang="en">has base power points</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://pokeknowledge.org/ontology#cardinalRestrictions -->

    <owl:DatatypeProperty rdf:about="https://pokeknowledge.org/ontology#cardinalRestrictions">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label xml:lang="en">cardinal Restrictions</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- https://pokeknowledge.org/ontology#defense -->

    <owl:DatatypeProperty rdf:about="https://pokeknowledge.org/ontology#defense">
        <rdfs:domain rdf:resource="https://pokeknowledge.org/ontology#Pokémon"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:label xml:lang="en">has Defense</rdfs:label>
    </owl:DatatypeProperty>
    


