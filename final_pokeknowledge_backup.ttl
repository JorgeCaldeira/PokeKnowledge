@prefix : <https://pokeknowledge.org/ontology#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <https://pokeknowledge.org/ontology#> .

<https://pokeknowledge.org/ontology> rdf:type owl:Ontology ;
                                      owl:versionIRI <https://pokeknowledge.org/ontology/version/1.0.0> ;
                                      rdfs:comment "A Knowledge Graph for Pokémon and their types from the Pokémon Sword & Shield Games."@en ;
                                      rdfs:label "PokéKnowledge"@en .

#################################################################
#    Datatypes
#################################################################

###  http://www.w3.org/2001/XMLSchema#date
xsd:date rdf:type rdfs:Datatype .


#################################################################
#    Object Properties
#################################################################

###  https://pokeknowledge.org/ontology#containsPlace
:containsPlace rdf:type owl:ObjectProperty ;
               owl:inverseOf :locatedIn ;
               rdf:type owl:AsymmetricProperty ,
                        owl:TransitiveProperty ;
               rdfs:domain :Place ;
               rdfs:range :Place ;
               rdfs:label "contains place"@en .


###  https://pokeknowledge.org/ontology#describedInPokédex
:describedInPokédex rdf:type owl:ObjectProperty ;
                    owl:inverseOf :describesPokémon ;
                    rdf:type owl:InverseFunctionalProperty ;
                    rdfs:domain :Pokémon ;
                    rdfs:range :PokédexEntry ;
                    rdfs:label "described in Pokédex entry"@en .


###  https://pokeknowledge.org/ontology#describesPokémon
:describesPokémon rdf:type owl:ObjectProperty ,
                           owl:FunctionalProperty ;
                  rdfs:domain :PokédexEntry ;
                  rdfs:range :Pokémon ;
                  rdfs:label "describes Pokémon"@en .


###  https://pokeknowledge.org/ontology#evolvesFrom
:evolvesFrom rdf:type owl:ObjectProperty ;
             owl:inverseOf :evolvesTo ;
             rdfs:domain :Pokémon ;
             rdfs:range :Pokémon ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :maxNumberOfPokémon ;
                          owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                          owl:onDataRange xsd:int
                        ] ;
             rdfs:label "evolves from"@en .


###  https://pokeknowledge.org/ontology#evolvesTo
:evolvesTo rdf:type owl:ObjectProperty ;
           rdfs:domain :Pokémon ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :maxNumberOfPokémon ;
                         owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                         owl:onDataRange xsd:int
                       ] ;
           rdfs:range :Pokémon ;
           rdfs:label "evolves to"@en .


###  https://pokeknowledge.org/ontology#exclusiveToGame
:exclusiveToGame rdf:type owl:ObjectProperty ;
                 rdfs:domain :Pokémon ;
                 rdfs:range :Game ,
                            [ rdf:type owl:Restriction ;
                              owl:onProperty :maxNumberOfPokémon ;
                              owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                              owl:onDataRange xsd:int
                            ] ;
                 rdfs:label "exclusive to Game"@en .


###  https://pokeknowledge.org/ontology#featuresSpecies
:featuresSpecies rdf:type owl:ObjectProperty ,
                          owl:AsymmetricProperty ;
                 rdfs:range :Pokémon ;
                 owl:propertyChainAxiom ( :hasPokédexEntry
                                          :describesPokémon
                                        ) ;
                 rdfs:label "features Species"@en .


###  https://pokeknowledge.org/ontology#foundIn
:foundIn rdf:type owl:ObjectProperty ;
         rdfs:domain :Pokémon ;
         rdfs:range :Habitat ;
         rdfs:label "found in"@en .


###  https://pokeknowledge.org/ontology#hasGame
:hasGame rdf:type owl:ObjectProperty ;
         owl:inverseOf :hasRegion ;
         rdfs:domain :Generation ,
                     :Region ;
         rdfs:range :Game ;
         owl:propertyDisjointWith :hasRegion ;
         rdfs:label "has Game"@en .


###  https://pokeknowledge.org/ontology#hasLeader
:hasLeader rdf:type owl:ObjectProperty ;
           owl:inverseOf :isLeaderOfGym ;
           rdfs:domain :Gym ;
           rdfs:range :GymLeader ;
           rdfs:label "has Leader"@en .


###  https://pokeknowledge.org/ontology#hasMove
:hasMove rdf:type owl:ObjectProperty ;
         rdfs:domain :Pokémon ,
                     [ rdf:type owl:Restriction ;
                       owl:onProperty :minMovesInActiveMoveset ;
                       owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                       owl:onDataRange xsd:int
                     ] ,
                     [ rdf:type owl:Restriction ;
                       owl:onProperty :maxMovesInActiveMoveset ;
                       owl:maxQualifiedCardinality "4"^^xsd:nonNegativeInteger ;
                       owl:onDataRange xsd:int
                     ] ;
         rdfs:range :Move ,
                    [ rdf:type owl:Restriction ;
                      owl:onProperty :minMovesInActiveMoveset ;
                      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                      owl:onDataRange xsd:int
                    ] ,
                    [ rdf:type owl:Restriction ;
                      owl:onProperty :maxMovesInActiveMoveset ;
                      owl:maxQualifiedCardinality "4"^^xsd:nonNegativeInteger ;
                      owl:onDataRange xsd:int
                    ] ;
         rdfs:label "has Move"@en .


###  https://pokeknowledge.org/ontology#hasPokédexEntry
:hasPokédexEntry rdf:type owl:ObjectProperty ,
                          owl:InverseFunctionalProperty ;
                 rdfs:domain :Pokédex ;
                 rdfs:range :PokédexEntry ;
                 rdfs:label "has Pokédex entry"@en .


###  https://pokeknowledge.org/ontology#hasPokémonInTeam
:hasPokémonInTeam rdf:type owl:ObjectProperty ;
                  rdfs:domain :Trainer ;
                  rdfs:range :Pokémon ;
                  rdfs:label "has Pokémon in Team"@en .


###  https://pokeknowledge.org/ontology#hasRegion
:hasRegion rdf:type owl:ObjectProperty ;
           rdfs:domain :Game ;
           rdfs:range :Region ;
           rdfs:label "has Region"@en .


###  https://pokeknowledge.org/ontology#hasSize
:hasSize rdf:type owl:ObjectProperty ;
         rdfs:label "has size"@en .


###  https://pokeknowledge.org/ontology#hasTeam
:hasTeam rdf:type owl:ObjectProperty ;
         rdfs:domain :Trainer ;
         rdfs:range :Pokémon ,
                    :Team ,
                    [ rdf:type owl:Restriction ;
                      owl:onProperty :minNumberOfPokémon ;
                      owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                      owl:onDataRange xsd:int
                    ] ,
                    [ rdf:type owl:Restriction ;
                      owl:onProperty :maxNumberOfPokémon ;
                      owl:maxQualifiedCardinality "6"^^xsd:nonNegativeInteger ;
                      owl:onDataRange xsd:int
                    ] ;
         rdfs:label "has Team"@en .


###  https://pokeknowledge.org/ontology#hasType
:hasType rdf:type owl:ObjectProperty ;
         rdfs:domain :Move ,
                     :Pokémon ;
         rdfs:range :Type ,
                    [ rdf:type owl:Restriction ;
                      owl:onProperty :minNumPokémonTypes ;
                      owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                      owl:onDataRange xsd:int
                    ] ,
                    [ rdf:type owl:Restriction ;
                      owl:onProperty :moveType ;
                      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                      owl:onDataRange xsd:int
                    ] ,
                    [ rdf:type owl:Restriction ;
                      owl:onProperty :maxNumPokémonTypes ;
                      owl:maxQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
                      owl:onDataRange xsd:integer
                    ] ;
         rdfs:label "has Type"@en .


###  https://pokeknowledge.org/ontology#has_Gym
:has_Gym rdf:type owl:ObjectProperty ;
         owl:inverseOf :is_located_in_Town ;
         rdfs:domain :Gym ;
         rdfs:range :Town ;
         rdfs:label "has Gym"@en .


###  https://pokeknowledge.org/ontology#isHarmlessAgainst
:isHarmlessAgainst rdf:type owl:ObjectProperty ;
                   owl:inverseOf :isImmuneTo ;
                   rdfs:domain :Type ;
                   rdfs:range :Type ;
                   owl:propertyDisjointWith :isSuperEffectiveAgainst ,
                                            :isWeakAgainst ;
                   rdfs:label "is Harmless against"@en .


###  https://pokeknowledge.org/ontology#isImmuneTo
:isImmuneTo rdf:type owl:ObjectProperty ;
            rdfs:domain :Type ;
            rdfs:range :Type ;
            owl:propertyDisjointWith :isResistantTo ,
                                     :isVulnerableTo ;
            rdfs:label "is Immune to"@en .


###  https://pokeknowledge.org/ontology#isInTeam
:isInTeam rdf:type owl:ObjectProperty ;
          rdfs:domain :Pokémon ;
          rdfs:range :Team ;
          rdfs:label "is In Team"@en .


###  https://pokeknowledge.org/ontology#isLeaderOfGym
:isLeaderOfGym rdf:type owl:ObjectProperty ;
               rdfs:domain :GymLeader ;
               rdfs:range :Gym ;
               rdfs:label "is leader of gym"@en .


###  https://pokeknowledge.org/ontology#isResistantTo
:isResistantTo rdf:type owl:ObjectProperty ;
               owl:inverseOf :isWeakAgainst ;
               rdfs:domain :Type ;
               rdfs:range :Type ;
               owl:propertyDisjointWith :isVulnerableTo ;
               rdfs:label "is Resistant to"@en .


###  https://pokeknowledge.org/ontology#isSuperEffectiveAgainst
:isSuperEffectiveAgainst rdf:type owl:ObjectProperty ;
                         owl:inverseOf :isVulnerableTo ;
                         rdfs:domain :Type ;
                         rdfs:range :Type ;
                         owl:propertyDisjointWith :isWeakAgainst ;
                         rdfs:label "is Super Effective against"@en .


###  https://pokeknowledge.org/ontology#isVulnerableTo
:isVulnerableTo rdf:type owl:ObjectProperty ;
                rdfs:domain :Type ;
                rdfs:range :Type ;
                rdfs:label "is Vulnerable to"@en .


###  https://pokeknowledge.org/ontology#isWeakAgainst
:isWeakAgainst rdf:type owl:ObjectProperty ;
               rdfs:domain :Type ;
               rdfs:range :Type ;
               rdfs:label "is Weak against"@en .


###  https://pokeknowledge.org/ontology#is_located_in_Town
:is_located_in_Town rdf:type owl:ObjectProperty ;
                    rdfs:domain :Town ;
                    rdfs:range :Gym ;
                    rdfs:label "is located in Town"@en .


###  https://pokeknowledge.org/ontology#learnsMove
:learnsMove rdf:type owl:ObjectProperty ;
            rdfs:domain :MoveLearning ;
            rdfs:range :Move ;
            rdfs:label "learns Move"@en .


###  https://pokeknowledge.org/ontology#locatedIn
:locatedIn rdf:type owl:ObjectProperty ,
                    owl:AsymmetricProperty ,
                    owl:TransitiveProperty ;
           rdfs:domain :Place ;
           rdfs:range :Place ;
           rdfs:label "located in"@en .


###  https://pokeknowledge.org/ontology#mayHaveAbility
:mayHaveAbility rdf:type owl:ObjectProperty ;
                rdfs:domain :Pokémon ;
                rdfs:range :Ability ;
                rdfs:label "may have Ability"@en .


###  https://pokeknowledge.org/ontology#mayHaveHiddenAbility
:mayHaveHiddenAbility rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf :mayHaveAbility ;
                      rdfs:domain :Pokémon ;
                      rdfs:range :Ability ;
                      rdfs:label "may have hidden ability"@en .


#################################################################
#    Data properties
#################################################################

###  https://pokeknowledge.org/ontology#accuracy
:accuracy rdf:type owl:DatatypeProperty ;
          rdfs:domain :Move ;
          rdfs:range xsd:integer ;
          rdfs:label "has accuracy"@en .


###  https://pokeknowledge.org/ontology#attack
:attack rdf:type owl:DatatypeProperty ;
        rdfs:domain :Pokémon ;
        rdfs:range xsd:integer ;
        rdfs:label "has Attack"@en .


###  https://pokeknowledge.org/ontology#basePower
:basePower rdf:type owl:DatatypeProperty ;
           rdfs:domain :Move ;
           rdfs:range xsd:integer ;
           rdfs:label "has base power"@en .


###  https://pokeknowledge.org/ontology#basePowerPoints
:basePowerPoints rdf:type owl:DatatypeProperty ;
                 rdfs:subPropertyOf owl:topDataProperty ;
                 rdfs:domain :Move ;
                 rdfs:range xsd:integer ;
                 rdfs:label "has base power points"@en .


###  https://pokeknowledge.org/ontology#cardinalRestrictions
:cardinalRestrictions rdf:type owl:DatatypeProperty ;
                      rdfs:range xsd:integer ;
                      rdfs:label "cardinal Restrictions"@en .


###  https://pokeknowledge.org/ontology#defense
:defense rdf:type owl:DatatypeProperty ;
         rdfs:domain :Pokémon ;
         rdfs:range xsd:integer ;
         rdfs:label "has Defense"@en .


###  https://pokeknowledge.org/ontology#effectDescription
:effectDescription rdf:type owl:DatatypeProperty ;
                   rdfs:domain [ rdf:type owl:Class ;
                                 owl:unionOf ( :Ability
                                               :Move
                                             )
                               ] ;
                   rdfs:label "effect description"@en .


###  https://pokeknowledge.org/ontology#entryNumber
:entryNumber rdf:type owl:DatatypeProperty ,
                      owl:FunctionalProperty ;
             rdfs:domain :PokédexEntry ;
             rdfs:range xsd:int ;
             rdfs:label "has entry number"@en .


###  https://pokeknowledge.org/ontology#hp
:hp rdf:type owl:DatatypeProperty ;
    rdfs:domain :Pokémon ;
    rdfs:range xsd:integer ;
    rdfs:label "has HP"@en .


###  https://pokeknowledge.org/ontology#maxMovesInActiveMoveset
:maxMovesInActiveMoveset rdf:type owl:DatatypeProperty ;
                         rdfs:subPropertyOf :cardinalRestrictions ;
                         rdfs:domain :Pokémon ;
                         rdfs:range xsd:integer ;
                         rdfs:label "max Moves in Active Moveset"@en .


###  https://pokeknowledge.org/ontology#maxNumPokémonTypes
:maxNumPokémonTypes rdf:type owl:DatatypeProperty ;
                    rdfs:subPropertyOf :cardinalRestrictions ;
                    rdfs:domain :Pokémon ,
                                :Type ;
                    rdfs:range xsd:integer ;
                    rdfs:label "max Num Pokémon Types" .


###  https://pokeknowledge.org/ontology#maxNumberOfPokémon
:maxNumberOfPokémon rdf:type owl:DatatypeProperty ;
                    rdfs:subPropertyOf :cardinalRestrictions ;
                    rdfs:domain :Game ,
                                :Pokémon ;
                    rdfs:range xsd:integer ;
                    rdfs:label "max Num of Pokémon" .


###  https://pokeknowledge.org/ontology#maxPowerPoints
:maxPowerPoints rdf:type owl:DatatypeProperty ;
                rdfs:domain :Move ;
                rdfs:range xsd:integer ;
                rdfs:label "has maximum Power Points"@en .


###  https://pokeknowledge.org/ontology#minLevelToLearn
:minLevelToLearn rdf:type owl:DatatypeProperty ;
                 rdfs:label "needs minimum level to learn"@en .


###  https://pokeknowledge.org/ontology#minMovesInActiveMoveset
:minMovesInActiveMoveset rdf:type owl:DatatypeProperty ;
                         rdfs:subPropertyOf :cardinalRestrictions ;
                         rdfs:domain :Pokémon ;
                         rdfs:range xsd:integer ;
                         rdfs:label "min Moves in active moveset"@en .


###  https://pokeknowledge.org/ontology#minNumPokémonTypes
:minNumPokémonTypes rdf:type owl:DatatypeProperty ;
                    rdfs:subPropertyOf :cardinalRestrictions ;
                    rdfs:domain :Pokémon ,
                                :Type ;
                    rdfs:range xsd:integer ;
                    rdfs:label "min Num Pokémon Types"@en .


###  https://pokeknowledge.org/ontology#minNumberOfPokémon
:minNumberOfPokémon rdf:type owl:DatatypeProperty ;
                    rdfs:subPropertyOf :cardinalRestrictions ;
                    rdfs:range xsd:integer ;
                    rdfs:label "min Num of Pokémon"@en .


###  https://pokeknowledge.org/ontology#moveType
:moveType rdf:type owl:DatatypeProperty ;
          rdfs:subPropertyOf :cardinalRestrictions ;
          rdfs:domain :Move ,
                      :Type ;
          rdfs:range xsd:integer ;
          rdfs:label "move Type"@en .


###  https://pokeknowledge.org/ontology#spAtk
:spAtk rdf:type owl:DatatypeProperty ;
       rdfs:domain :Pokémon ;
       rdfs:range xsd:integer ;
       rdfs:label "has Special Attack"@en .


###  https://pokeknowledge.org/ontology#spDef
:spDef rdf:type owl:DatatypeProperty ;
       rdfs:domain :Pokémon ;
       rdfs:range xsd:integer ;
       rdfs:label "has Special Defense"@en .


###  https://pokeknowledge.org/ontology#speed
:speed rdf:type owl:DatatypeProperty ;
       rdfs:domain :Pokémon ;
       rdfs:range xsd:integer ;
       rdfs:label "has Speed"@en .


#################################################################
#    Classes
#################################################################

###  http://xmlns.com/foaf/0.1/Person
foaf:Person rdf:type owl:Class .


###  https://pokeknowledge.org/ontology#Ability
:Ability rdf:type owl:Class ;
         rdfs:comment "Game mechanic that provides passive effects to a certain Pokémon."@en ;
         rdfs:label "Ability"@en .


###  https://pokeknowledge.org/ontology#Game
:Game rdf:type owl:Class ;
      rdfs:comment "The Pokémon game."@en ;
      rdfs:label "Game"@en .


###  https://pokeknowledge.org/ontology#Generation
:Generation rdf:type owl:Class ;
            rdfs:comment "The generation of Pokémon."@en ;
            rdfs:label "Generation"@en .


###  https://pokeknowledge.org/ontology#Gym
:Gym rdf:type owl:Class ;
     rdfs:subClassOf :Place ;
     rdfs:comment "The place where Pokémon Trainers train their Pokémon."@en ;
     rdfs:label "Gym"@en .


###  https://pokeknowledge.org/ontology#GymLeader
:GymLeader rdf:type owl:Class ;
           rdfs:subClassOf :Trainer ;
           rdfs:comment "The Pokémon Trainer that leads a team in a specific Gym."@en ;
           rdfs:label "Gym Leader"@en .


###  https://pokeknowledge.org/ontology#HM
:HM rdf:type owl:Class ;
    rdfs:subClassOf :MoveLearning ;
    rdfs:label "Hidden Machine"@en .


###  https://pokeknowledge.org/ontology#Habitat
:Habitat rdf:type owl:Class ;
         rdfs:comment "The biome where a Pokémon lives."@en ;
         rdfs:label "Habitat"@en .


###  https://pokeknowledge.org/ontology#LearningByLevelingUp
:LearningByLevelingUp rdf:type owl:Class ;
                      rdfs:subClassOf :MoveLearning ;
                      rdfs:label "Learning by leveling up"@en .


###  https://pokeknowledge.org/ontology#LearningThroughBreeding
:LearningThroughBreeding rdf:type owl:Class ;
                         rdfs:subClassOf :MoveLearning ;
                         rdfs:label "Learning through breeding"@en .


###  https://pokeknowledge.org/ontology#Move
:Move rdf:type owl:Class ;
      rdfs:comment "The skill a Pokémon uses in battle."@en ;
      rdfs:label "Move"@en .


###  https://pokeknowledge.org/ontology#MoveLearning
:MoveLearning rdf:type owl:Class ;
              rdfs:comment "The methods by which a Pokémon can acquire a move."@en ;
              rdfs:label "Move learning"@en .


###  https://pokeknowledge.org/ontology#PhysicalMove
:PhysicalMove rdf:type owl:Class ;
              rdfs:subClassOf :Move ;
              rdfs:label "Physical Move"@en .


###  https://pokeknowledge.org/ontology#Place
:Place rdf:type owl:Class ;
       rdfs:comment "The in-game places."@en ;
       rdfs:label "Place"@en .


###  https://pokeknowledge.org/ontology#Pokédex
:Pokédex rdf:type owl:Class ;
         owl:disjointUnionOf ( :Pokémon
                               :Type
                             ) ;
         rdfs:comment "The tool that contains information about all Pokémon."@en ;
         rdfs:label "Pokédex"@en .


###  https://pokeknowledge.org/ontology#PokédexEntry
:PokédexEntry rdf:type owl:Class ;
              owl:disjointUnionOf ( :Move
                                    :Pokédex
                                    :Pokémon
                                    :Type
                                  ) ;
              rdfs:comment "An entry inside of the Pokédex that describes and gives information about a certain Pokémon."@en ;
              rdfs:label "Pokédex Entry"@en .


###  https://pokeknowledge.org/ontology#Pokémon
:Pokémon rdf:type owl:Class ;
         owl:disjointUnionOf ( :Pokédex
                               :Type
                             ) ;
         rdfs:comment "The in-game creatures."@en ;
         rdfs:label "Pokémon"@en .


###  https://pokeknowledge.org/ontology#Region
:Region rdf:type owl:Class ;
        rdfs:subClassOf :Place ;
        rdfs:comment "The in-game regions."@en ;
        rdfs:label "Region"@en .


###  https://pokeknowledge.org/ontology#Route
:Route rdf:type owl:Class ;
       rdfs:comment "A passage that allows Trainers to travel between locations."@en ;
       rdfs:label "Route"@en .


###  https://pokeknowledge.org/ontology#SpecialMove
:SpecialMove rdf:type owl:Class ;
             rdfs:subClassOf :Move ;
             rdfs:label "Special Move"@en .


###  https://pokeknowledge.org/ontology#StatusMove
:StatusMove rdf:type owl:Class ;
            rdfs:subClassOf :Move ;
            rdfs:label "Status Move"@en .


###  https://pokeknowledge.org/ontology#TM
:TM rdf:type owl:Class ;
    rdfs:subClassOf :MoveLearning ;
    rdfs:label "Technical Machine"@en .


###  https://pokeknowledge.org/ontology#Team
:Team rdf:type owl:Class ;
      rdfs:comment "A group of a variable number of Pokémon."@en ;
      rdfs:label "Team"@en .


###  https://pokeknowledge.org/ontology#Town
:Town rdf:type owl:Class ;
      rdfs:subClassOf :Region ;
      rdfs:comment "The in-game towns inside of regions."@en ;
      rdfs:label "Town"@en .


###  https://pokeknowledge.org/ontology#Trainer
:Trainer rdf:type owl:Class ;
         rdfs:subClassOf foaf:Person ;
         rdfs:comment "An individual that trains Pokémon."@en ;
         rdfs:label "Trainer"@en .


###  https://pokeknowledge.org/ontology#Type
:Type rdf:type owl:Class ;
      owl:disjointUnionOf ( :Pokédex
                            :Pokémon
                          ) ;
      rdfs:comment "Properties applied to Pokémon and their Moves."@en ;
      rdfs:label "Type"@en .


#################################################################
#    Individuals
#################################################################

###  https://pokeknowledge.org/ontology#Allister
:Allister rdf:type owl:NamedIndividual ,
                   :GymLeader ;
          :hasPokémonInTeam <https://pokeknowledge.org/resource/Galarian_Cursola> ,
                            <https://pokeknowledge.org/resource/Galarian_Yamask> ,
                            <https://pokeknowledge.org/resource/Gengar> ,
                            <https://pokeknowledge.org/resource/Mimikyu> ;
          :isLeaderOfGym :Stow-on-Side ;
          rdfs:label "Allister"@en .


###  https://pokeknowledge.org/ontology#Avery
:Avery rdf:type owl:NamedIndividual ,
                :GymLeader ;
       :isLeaderOfGym :The_Isle_of_Armor ;
       rdfs:label "Avery"@en .


###  https://pokeknowledge.org/ontology#Ballonlea
:Ballonlea rdf:type owl:NamedIndividual ,
                    :Gym ;
           :hasType :PokéType_Fairy ;
           :is_located_in_Town :Ballonlea_Town ;
           rdfs:label "Ballonlea Gym"@en .


###  https://pokeknowledge.org/ontology#Ballonlea_Town
:Ballonlea_Town rdf:type owl:NamedIndividual ,
                         :Town ;
                :has_Gym :Ballonlea ;
                rdfs:label "Ballonlea"@en .


###  https://pokeknowledge.org/ontology#Bea
:Bea rdf:type owl:NamedIndividual ,
              :GymLeader ;
     :hasPokémonInTeam <https://pokeknowledge.org/resource/Hitmontop> ,
                       <https://pokeknowledge.org/resource/Machamp> ,
                       <https://pokeknowledge.org/resource/Pangoro> ,
                       <https://pokeknowledge.org/resource/Sirfetch’d> ;
     :isLeaderOfGym :Stow-on-Side ;
     rdfs:label "Bea"@en .


###  https://pokeknowledge.org/ontology#Circhester
:Circhester rdf:type owl:NamedIndividual ,
                     :Gym ;
            :hasType :PokéType_Ice ,
                     :PokéType_Rock ;
            :is_located_in_Town :Circhester_Town ;
            rdfs:label "Circhester Gym"@en .


###  https://pokeknowledge.org/ontology#Circhester_Town
:Circhester_Town rdf:type owl:NamedIndividual ,
                          :Town ;
                 :has_Gym :Circhester ;
                 rdfs:label "Circhester"@en .


###  https://pokeknowledge.org/ontology#Freezington_Town
:Freezington_Town rdf:type owl:NamedIndividual ,
                           :Town ;
                  rdfs:label "Freezington" .


###  https://pokeknowledge.org/ontology#Generation_I
:Generation_I rdf:type owl:NamedIndividual ,
                       :Generation ;
