:evolvesTo a owl:ObjectProperty ;
    rdfs:label "evolves to"@en ;
    rdfs:domain [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:int ;
            owl:onProperty :maxNumberOfPokémon ],
        :Pokémon ;
    rdfs:range :Pokémon .

:hasPokédexEntry a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "has Pokédex entry"@en ;
    rdfs:domain :Pokédex ;
    rdfs:range :PokédexEntry .

:isImmuneTo a owl:ObjectProperty ;
    rdfs:label "is Immune to"@en ;
    rdfs:domain :Type ;
    rdfs:range :Type ;
    owl:propertyDisjointWith :isResistantTo,
        :isVulnerableTo .

:isLeaderOfGym a owl:ObjectProperty ;
    rdfs:label "is leader of gym"@en ;
    rdfs:domain :GymLeader ;
    rdfs:range :Gym .

:isResistantTo a owl:ObjectProperty ;
    rdfs:label "is Resistant to"@en ;
    rdfs:domain :Type ;
    rdfs:range :Type ;
    owl:inverseOf :isWeakAgainst ;
    owl:propertyDisjointWith :isVulnerableTo .

:isSuperEffectiveAgainst a owl:ObjectProperty ;
    rdfs:label "is Super Effective against"@en ;
    rdfs:domain :Type ;
    rdfs:range :Type ;
    owl:inverseOf :isVulnerableTo ;
    owl:propertyDisjointWith :isWeakAgainst .

:is_located_in_Town a owl:ObjectProperty ;
    rdfs:label "is located in Town"@en ;
    rdfs:domain :Town ;
    rdfs:range :Gym .

:locatedIn a owl:AsymmetricProperty,
        owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "located in"@en ;
    rdfs:domain :Place ;
    rdfs:range :Place .

:maxNumPokémonTypes a owl:DatatypeProperty ;
    rdfs:label "max Num Pokémon Types" ;
    rdfs:domain :Pokémon,
        :Type ;
    rdfs:range xsd:integer ;
    rdfs:subPropertyOf :cardinalRestrictions .

:mayHaveAbility a owl:ObjectProperty ;
    rdfs:label "may have Ability"@en ;
    rdfs:domain :Pokémon ;
    rdfs:range :Ability .

:minNumPokémonTypes a owl:DatatypeProperty ;
    rdfs:label "min Num Pokémon Types"@en ;
    rdfs:domain :Pokémon,
        :Type ;
    rdfs:range xsd:integer ;
    rdfs:subPropertyOf :cardinalRestrictions .

:minNumberOfPokémon a owl:DatatypeProperty ;
    rdfs:label "min Num of Pokémon"@en ;
    rdfs:range xsd:integer ;
    rdfs:subPropertyOf :cardinalRestrictions .

:moveType a owl:DatatypeProperty ;
    rdfs:label "move Type"@en ;
    rdfs:domain :Move,
        :Type ;
    rdfs:range xsd:integer ;
    rdfs:subPropertyOf :cardinalRestrictions .

