@prefix : <https://pokeknowledge.org/ontology#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

xsd:date a rdfs:Datatype .

<https://pokeknowledge.org/ontology> a owl:Ontology ;
    rdfs:label "PokéKnowledge"@en ;
    rdfs:comment "A Knowledge Graph for Pokémon and their types from the Pokémon Sword & Shield Games."@en ;
    owl:versionIRI <https://pokeknowledge.org/ontology/version/1.0.0> .

:Allister a owl:NamedIndividual,
        :GymLeader ;
    rdfs:label "Allister"@en ;
    :hasPokémonInTeam <https://pokeknowledge.org/resource/Galarian_Cursola>,
        <https://pokeknowledge.org/resource/Galarian_Yamask>,
        <https://pokeknowledge.org/resource/Gengar>,
        <https://pokeknowledge.org/resource/Mimikyu> ;
    :isLeaderOfGym :Stow-on-Side .

:Avery a owl:NamedIndividual,
        :GymLeader ;
    rdfs:label "Avery"@en ;
    :isLeaderOfGym :The_Isle_of_Armor .

:Bea a owl:NamedIndividual,
        :GymLeader ;
    rdfs:label "Bea"@en ;
    :hasPokémonInTeam <https://pokeknowledge.org/resource/Hitmontop>,
        <https://pokeknowledge.org/resource/Machamp>,
        <https://pokeknowledge.org/resource/Pangoro>,
        <https://pokeknowledge.org/resource/Sirfetch’d> ;
    :isLeaderOfGym :Stow-on-Side .

:Freezington_Town a owl:NamedIndividual,
        :Town ;
    rdfs:label "Freezington" .

:Generation_I a owl:NamedIndividual,
        :Generation ;
    :hasGame :Pokémon_Blue,
        :Pokémon_Green,
        :Pokémon_Red,
        :Pokémon_Yellow .

:Generation_II a owl:NamedIndividual,
        :Generation ;
    :hasGame :Pokémon_Crystal,
        :Pokémon_Gold,
        :Pokémon_Silver .

:Generation_III a owl:NamedIndividual,
        :Generation ;
    :hasGame :Pokémon_Emerald,
        :Pokémon_FireRed,
        :Pokémon_LeafGreen,
        :Pokémon_Ruby,
        :Pokémon_Sapphire .

:Generation_IV a owl:NamedIndividual,
        :Generation ;
    :hasGame :Pokémon_Diamond,
        :Pokémon_HeartGold,
        :Pokémon_Pearl,
        :Pokémon_Platinum,
        :Pokémon_SoulSilver .

:Generation_IX a owl:NamedIndividual,
        :Generation ;
    rdfs:label "Generation IX"@en ;
    :hasGame :Pokémon_Scarlet,
        :Pokémon_Violet .

:Generation_V a owl:NamedIndividual,
        :Generation ;
    :hasGame :Pokémon_Black,
        :Pokémon_Black2,
        :Pokémon_White,
        :Pokémon_White2 .

:Generation_VI a owl:NamedIndividual,
        :Generation ;
    :hasGame :Pokémon_AlphaSapphire,
        :Pokémon_OmegaRuby,
        :Pokémon_X,
        :Pokémon_Y .

:Generation_VII a owl:NamedIndividual,
        :Generation ;
    :hasGame :Pokémon_Moon,
        :Pokémon_Sun,
        :Pokémon_UltraMoon,
        :Pokémon_UltraSun .

:Generation_VIII a owl:NamedIndividual,
        :Generation ;
    :hasGame :Pokémon_BrilliantDiamond,
        :Pokémon_Shield,
        :Pokémon_ShiningPearl,
        :Pokémon_Sword .

:Gordie a owl:NamedIndividual,
        :GymLeader ;
    rdfs:label "Gordie"@en ;
    :hasPokémonInTeam <https://pokeknowledge.org/resource/Barbaracle>,
        <https://pokeknowledge.org/resource/Coalossal>,
        <https://pokeknowledge.org/resource/Shuckle>,
        <https://pokeknowledge.org/resource/Stonjourner> ;
    :isLeaderOfGym :Circhester .

:HM a owl:Class ;
    rdfs:label "Hidden Machine"@en ;
    rdfs:subClassOf :MoveLearning .

:Habitat_Cave a owl:NamedIndividual,
        :Habitat ;
    rdfs:label "Cave"@en .

:Habitat_Forest a owl:NamedIndividual,
        :Habitat ;
    rdfs:label "Forest"@en .

:Habitat_Grassland a owl:NamedIndividual,
        :Habitat ;
    rdfs:label "Grassland"@en .

:Habitat_Mountain a owl:NamedIndividual,
        :Habitat ;
    rdfs:label "Mountain"@en .

:Habitat_Rare a owl:NamedIndividual,
        :Habitat ;
    rdfs:label "Rare"@en .

:Habitat_RoughTerrain a owl:NamedIndividual,
        :Habitat ;
    rdfs:label "Rough terrain"@en .

:Habitat_Sea a owl:NamedIndividual,
        :Habitat ;
    rdfs:label "Sea"@en .

:Habitat_Urban a owl:NamedIndividual,
        :Habitat ;
    rdfs:label "Urban"@en .

:Habitat_WatersEdge a owl:NamedIndividual,
        :Habitat ;
    rdfs:label "Water's edge"@en .

:Kabu a owl:NamedIndividual,
        :GymLeader ;
    rdfs:label "Kabu"@en ;
    :hasPokémonInTeam <https://pokeknowledge.org/resource/Arcanine>,
        <https://pokeknowledge.org/resource/Centiskorch>,
        <https://pokeknowledge.org/resource/Ninetales> ;
