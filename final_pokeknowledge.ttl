:Klara a owl:NamedIndividual,
        :GymLeader ;
    rdfs:label "Klara"@en ;
    :isLeaderOfGym :The_Isle_of_Armor .

:LearningByLevelingUp a owl:Class ;
    rdfs:label "Learning by leveling up"@en ;
    rdfs:subClassOf :MoveLearning .

:LearningThroughBreeding a owl:Class ;
    rdfs:label "Learning through breeding"@en ;
    rdfs:subClassOf :MoveLearning .

:Melony a owl:NamedIndividual,
        :GymLeader ;
    rdfs:label "Melony"@en ;
    :hasPokémonInTeam <https://pokeknowledge.org/resource/Eiscue>,
        <https://pokeknowledge.org/resource/Frosmoth>,
        <https://pokeknowledge.org/resource/Galarian_Darmanitan>,
        <https://pokeknowledge.org/resource/Lapras> ;
    :isLeaderOfGym :Circhester .

:Milo a owl:NamedIndividual,
        :GymLeader ;
    rdfs:label "Milo"@en ;
    :hasPokémonInTeam <https://pokeknowledge.org/resource/Eldegoss>,
        <https://pokeknowledge.org/resource/Gossifleur> ;
    :isLeaderOfGym :Turffield .

:Nessa a owl:NamedIndividual,
        :GymLeader ;
    rdfs:label "Nessa"@en ;
    :hasPokémonInTeam <https://pokeknowledge.org/resource/Arrokuda>,
        <https://pokeknowledge.org/resource/Drednaw>,
        <https://pokeknowledge.org/resource/Goldeen> ;
    :isLeaderOfGym :Hulbury .

:Opal a owl:NamedIndividual,
        :GymLeader ;
    rdfs:label "Opal"@en ;
    :hasPokémonInTeam <https://pokeknowledge.org/resource/Alcremie>,
        <https://pokeknowledge.org/resource/Galarian_Weezing>,
        <https://pokeknowledge.org/resource/Mawile>,
        <https://pokeknowledge.org/resource/Togekiss> ;
    :isLeaderOfGym :Ballonlea .

:PhysicalMove a owl:Class ;
    rdfs:label "Physical Move"@en ;
    rdfs:subClassOf :Move .

:Piers a owl:NamedIndividual,
        :GymLeader ;
    rdfs:label "Piers"@en ;
    :hasPokémonInTeam <https://pokeknowledge.org/resource/Malamar>,
        <https://pokeknowledge.org/resource/Obstagoon>,
        <https://pokeknowledge.org/resource/Scrafty>,
        <https://pokeknowledge.org/resource/Skuntank> ;
    :isLeaderOfGym :Spikemuth .

:Postwick_Town a owl:NamedIndividual,
        :Town ;
    rdfs:label "Postwick"@en .

:Raihan a owl:NamedIndividual,
        :GymLeader ;
    rdfs:label "Raihan"@en ;
    :hasPokémonInTeam <https://pokeknowledge.org/resource/Duraludon>,
        <https://pokeknowledge.org/resource/Flygon>,
        <https://pokeknowledge.org/resource/Gigalith>,
        <https://pokeknowledge.org/resource/Sandaconda> ;
    :isLeaderOfGym :Hammerlocke .

:Route a owl:Class ;
    rdfs:label "Route"@en ;
    rdfs:comment "A passage that allows Trainers to travel between locations."@en .

:SpecialMove a owl:Class ;
    rdfs:label "Special Move"@en ;
    rdfs:subClassOf :Move .

:StatusMove a owl:Class ;
    rdfs:label "Status Move"@en ;
    rdfs:subClassOf :Move .

:TM a owl:Class ;
    rdfs:label "Technical Machine"@en ;
    rdfs:subClassOf :MoveLearning .

:Wedgehurst_Town a owl:NamedIndividual,
        :Town ;
    rdfs:label "Wedgehurst"@en .

:Wyndon_Town a owl:NamedIndividual,
        :Town ;
    rdfs:label "Wyndon"@en .

:accuracy a owl:DatatypeProperty ;
    rdfs:label "has accuracy"@en ;
    rdfs:domain :Move ;
    rdfs:range xsd:integer .

:attack a owl:DatatypeProperty ;
    rdfs:label "has Attack"@en ;
    rdfs:domain :Pokémon ;
    rdfs:range xsd:integer .

:basePower a owl:DatatypeProperty ;
    rdfs:label "has base power"@en ;
    rdfs:domain :Move ;
    rdfs:range xsd:integer .

:basePowerPoints a owl:DatatypeProperty ;
    rdfs:label "has base power points"@en ;
    rdfs:domain :Move ;
    rdfs:range xsd:integer ;
    rdfs:subPropertyOf owl:topDataProperty .

:containsPlace a owl:AsymmetricProperty,
        owl:ObjectProperty,
        owl:TransitiveProperty ;
    rdfs:label "contains place"@en ;
    rdfs:domain :Place ;
    rdfs:range :Place ;
    owl:inverseOf :locatedIn .

:defense a owl:DatatypeProperty ;
    rdfs:label "has Defense"@en ;
    rdfs:domain :Pokémon ;
    rdfs:range xsd:integer .

:describedInPokédex a owl:InverseFunctionalProperty,
        owl:ObjectProperty ;
    rdfs:label "described in Pokédex entry"@en ;
    rdfs:domain :Pokémon ;
    rdfs:range :PokédexEntry ;
    owl:inverseOf :describesPokémon .

:effectDescription a owl:DatatypeProperty ;
    rdfs:label "effect description"@en ;
    rdfs:domain [ a owl:Class ;
            owl:unionOf ( :Ability :Move ) ] .

:entryNumber a owl:DatatypeProperty,
        owl:FunctionalProperty ;
    rdfs:label "has entry number"@en ;
    rdfs:domain :PokédexEntry ;
    rdfs:range xsd:int .

:evolvesFrom a owl:ObjectProperty ;
    rdfs:label "evolves from"@en ;
    rdfs:domain :Pokémon ;
    rdfs:range [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:int ;
            owl:onProperty :maxNumberOfPokémon ],
        :Pokémon ;
    owl:inverseOf :evolvesTo .

:exclusiveToGame a owl:ObjectProperty ;
    rdfs:label "exclusive to Game"@en ;
    rdfs:domain :Pokémon ;
    rdfs:range [ a owl:Restriction ;
            owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:int ;
            owl:onProperty :maxNumberOfPokémon ],
        :Game .

:featuresSpecies a owl:AsymmetricProperty,
        owl:ObjectProperty ;
    rdfs:label "features Species"@en ;
    rdfs:range :Pokémon ;
    owl:propertyChainAxiom ( :hasPokédexEntry :describesPokémon ) .

:foundIn a owl:ObjectProperty ;
    rdfs:label "found in"@en ;
    rdfs:domain :Pokémon ;
    rdfs:range :Habitat .

:hasGame a owl:ObjectProperty ;
    rdfs:label "has Game"@en ;
    rdfs:domain :Generation,
        :Region ;
    rdfs:range :Game ;
    owl:inverseOf :hasRegion ;
    owl:propertyDisjointWith :hasRegion .

:hasLeader a owl:ObjectProperty ;
    rdfs:label "has Leader"@en ;
    rdfs:domain :Gym ;
    rdfs:range :GymLeader ;
    owl:inverseOf :isLeaderOfGym .

:hasMove a owl:ObjectProperty ;
    rdfs:label "has Move"@en ;
    rdfs:domain [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:int ;
            owl:onProperty :minMovesInActiveMoveset ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "4"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:int ;
            owl:onProperty :maxMovesInActiveMoveset ],
        :Pokémon ;
    rdfs:range [ a owl:Restriction ;
            owl:onDataRange xsd:int ;
            owl:onProperty :minMovesInActiveMoveset ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "4"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:int ;
            owl:onProperty :maxMovesInActiveMoveset ],
        :Move .

:hasPokémonInTeam a owl:ObjectProperty ;
    rdfs:label "has Pokémon in Team"@en ;
    rdfs:domain :Trainer ;
    rdfs:range :Pokémon .

:hasSize a owl:ObjectProperty ;
    rdfs:label "has size"@en .

:hasTeam a owl:ObjectProperty ;
    rdfs:label "has Team"@en ;
    rdfs:domain :Trainer ;
    rdfs:range [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:int ;
            owl:onProperty :minNumberOfPokémon ],
        [ a owl:Restriction ;
            owl:maxQualifiedCardinality "6"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:int ;
            owl:onProperty :maxNumberOfPokémon ],
        :Pokémon,
        :Team .

:hasType a owl:ObjectProperty ;
    rdfs:label "has Type"@en ;
    rdfs:domain :Move,
        :Pokémon ;
    rdfs:range [ a owl:Restriction ;
            owl:maxQualifiedCardinality "2"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:integer ;
            owl:onProperty :maxNumPokémonTypes ],
        [ a owl:Restriction ;
            owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
            owl:onDataRange xsd:int ;
            owl:onProperty :minNumPokémonTypes ],
        [ a owl:Restriction ;
            owl:onDataRange xsd:int ;
            owl:onProperty :moveType ;
            owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ],
        :Type .

:has_Gym a owl:ObjectProperty ;
    rdfs:label "has Gym"@en ;
    rdfs:domain :Gym ;
    rdfs:range :Town ;
    owl:inverseOf :is_located_in_Town .

:hp a owl:DatatypeProperty ;
    rdfs:label "has HP"@en ;
    rdfs:domain :Pokémon ;
    rdfs:range xsd:integer .

:isHarmlessAgainst a owl:ObjectProperty ;
    rdfs:label "is Harmless against"@en ;
    rdfs:domain :Type ;
    rdfs:range :Type ;
    owl:inverseOf :isImmuneTo ;
    owl:propertyDisjointWith :isSuperEffectiveAgainst,
        :isWeakAgainst .

:isInTeam a owl:ObjectProperty ;
    rdfs:label "is In Team"@en ;
    rdfs:domain :Pokémon ;
    rdfs:range :Team .

:learnsMove a owl:ObjectProperty ;
    rdfs:label "learns Move"@en ;
    rdfs:domain :MoveLearning ;
    rdfs:range :Move .

:maxPowerPoints a owl:DatatypeProperty ;
    rdfs:label "has maximum Power Points"@en ;
    rdfs:domain :Move ;
    rdfs:range xsd:integer .

:mayHaveHiddenAbility a owl:ObjectProperty ;
    rdfs:label "may have hidden ability"@en ;
    rdfs:domain :Pokémon ;
    rdfs:range :Ability ;
    rdfs:subPropertyOf :mayHaveAbility .

:minLevelToLearn a owl:DatatypeProperty ;
    rdfs:label "needs minimum level to learn"@en .

:spAtk a owl:DatatypeProperty ;
    rdfs:label "has Special Attack"@en ;
    rdfs:domain :Pokémon ;
    rdfs:range xsd:integer .

:spDef a owl:DatatypeProperty ;
    rdfs:label "has Special Defense"@en ;
    rdfs:domain :Pokémon ;
    rdfs:range xsd:integer .

:speed a owl:DatatypeProperty ;
    rdfs:label "has Speed"@en ;
    rdfs:domain :Pokémon ;
    rdfs:range xsd:integer .

